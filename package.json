{
    "name": "store-my-stuff",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "format": "prettier --check .",
        "check-types": "turbo run check-types",
        "test": "turbo run test",
        "prepare": "husky"
    },
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@eslint/js": "^10.0.1",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "prettier": "^3.9.1",
        "turbo": "^2.9.18",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.62.0"
    },
    "packageManager": "pnpm@10.4.1",
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yaml,yml}": [
            "prettier --write"
        ]
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "mongodb-memory-server"
        ],
        "overrides": {
            "human-id": "3.0.0"
        }
    }
}
